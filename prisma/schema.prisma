datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ─── Auth & Users ────────────────────────────────────────

enum Role {
  VISITOR
  CUSTOMER
  MEMBER
  STAFF
  ADMIN
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String?   @map("password_hash")
  name          String?
  role          Role      @default(CUSTOMER)
  image         String?
  bio           String?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  accounts      Account[]
  sessions      Session[]
  orders        Order[]
  cart          Cart?
  subscriptions Subscription[]
  blogPosts     BlogPost[]  @relation("author")
  courseProgress CourseProgress[]
  auditLogs     AuditLog[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Products & Shop ─────────────────────────────────────

enum ProductType {
  PHYSICAL
  DIGITAL
  SERVICE
  SUBSCRIPTION
}

model Product {
  id               String      @id @default(cuid())
  type             ProductType
  title            String
  slug             String      @unique
  description      String
  priceCents       Int         @map("price_cents")
  compareAtPrice   Int?        @map("compare_at_price_cents")
  active           Boolean     @default(true)
  images           String[]
  category         String
  featured         Boolean     @default(false)
  createdAt        DateTime    @default(now()) @map("created_at")

  variants         ProductVariant[]
  downloads        Download[]
  orderItems       OrderItem[]
  faqs             Faq[]

  @@map("products")
}

model ProductVariant {
  id         String @id @default(cuid())
  productId  String @map("product_id")
  sku        String @unique
  options    String @default("{}") // JSON: {size: "L", color: "black"}
  stockQty   Int    @default(-1) @map("stock_qty") // -1 = unlimited
  priceCents Int    @map("price_cents")

  product    Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  cartItems  CartItem[]
  orderItems OrderItem[]

  @@map("product_variants")
}

// ─── Cart ────────────────────────────────────────────────

model Cart {
  id        String     @id @default(cuid())
  userId    String?    @unique @map("user_id")
  anonId    String?    @map("anon_id")
  updatedAt DateTime   @updatedAt @map("updated_at")

  user      User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  items     CartItem[]

  @@map("carts")
}

model CartItem {
  id              String         @id @default(cuid())
  cartId          String         @map("cart_id")
  productVariantId String        @map("product_variant_id")
  qty             Int            @default(1)
  priceSnapshot   Int            @map("price_snapshot_cents")

  cart            Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productVariant  ProductVariant @relation(fields: [productVariantId], references: [id])

  @@unique([cartId, productVariantId])
  @@map("cart_items")
}

// ─── Orders ──────────────────────────────────────────────

enum OrderStatus {
  PENDING
  PAID
  FULFILLED
  DELIVERED
  REFUNDED
}

model Order {
  id                    String      @id @default(cuid())
  userId                String?     @map("user_id")
  status                OrderStatus @default(PENDING)
  subtotalCents         Int         @map("subtotal_cents")
  taxCents              Int         @default(0) @map("tax_cents")
  shippingCents         Int         @default(0) @map("shipping_cents")
  discountCents         Int         @default(0) @map("discount_cents")
  totalCents            Int         @map("total_cents")
  stripePaymentIntentId String?     @map("stripe_payment_intent_id")
  stripeCheckoutSessionId String?   @map("stripe_checkout_session_id")
  customerEmail         String?     @map("customer_email")
  shippingAddress       String?     @map("shipping_address")
  notes                 String?
  createdAt             DateTime    @default(now()) @map("created_at")

  user       User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  items      OrderItem[]

  @@map("orders")
}

model OrderItem {
  id               String         @id @default(cuid())
  orderId          String         @map("order_id")
  productVariantId String         @map("product_variant_id")
  productId        String         @map("product_id")
  qty              Int
  priceCents       Int            @map("price_cents")
  fulfillmentStatus String        @default("pending") @map("fulfillment_status")

  order           Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productVariant  ProductVariant @relation(fields: [productVariantId], references: [id])
  product         Product        @relation(fields: [productId], references: [id])

  @@map("order_items")
}

// ─── Digital Downloads ───────────────────────────────────

model Download {
  id           String @id @default(cuid())
  productId    String @map("product_id")
  fileKey      String @map("file_key")
  fileName     String @map("file_name")
  maxDownloads Int    @default(5) @map("max_downloads")

  product      Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  entitlements DownloadEntitlement[]

  @@map("downloads")
}

model DownloadEntitlement {
  id            String   @id @default(cuid())
  downloadId    String   @map("download_id")
  orderId       String?  @map("order_id")
  userEmail     String?  @map("user_email")
  downloadCount Int      @default(0) @map("download_count")
  expiresAt     DateTime? @map("expires_at")
  createdAt     DateTime @default(now()) @map("created_at")

  download Download @relation(fields: [downloadId], references: [id], onDelete: Cascade)

  @@map("download_entitlements")
}

// ─── Subscriptions ───────────────────────────────────────

model Subscription {
  id                  String   @id @default(cuid())
  userId              String   @map("user_id")
  stripeCustomerId    String   @map("stripe_customer_id")
  stripeSubscriptionId String  @map("stripe_subscription_id")
  plan                String
  status              String   @default("active")
  currentPeriodEnd    DateTime @map("current_period_end")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

// ─── Coupons ─────────────────────────────────────────────

model Coupon {
  id              String    @id @default(cuid())
  code            String    @unique
  type            String    // "percent" or "fixed"
  value           Int       // percent (10 = 10%) or cents (1000 = $10)
  minPurchase     Int       @default(0) @map("min_purchase_cents")
  maxUses         Int       @default(-1) @map("max_uses") // -1 = unlimited
  usesCount       Int       @default(0) @map("uses_count")
  active          Boolean   @default(true)
  expiresAt       DateTime? @map("expires_at")

  @@map("coupons")
}

// ─── Content ─────────────────────────────────────────────

model BlogPost {
  id              String    @id @default(cuid())
  title           String
  slug            String    @unique
  content         String
  excerpt         String?
  featuredImage   String?   @map("featured_image")
  category        String
  tags            String[]
  authorId        String    @map("author_id")
  published       Boolean   @default(false)
  publishedAt     DateTime? @map("published_at")
  seoTitle        String?   @map("seo_title")
  seoDescription  String?   @map("seo_description")
  createdAt       DateTime  @default(now()) @map("created_at")

  author User @relation("author", fields: [authorId], references: [id])

  @@map("blog_posts")
}

model Event {
  id          String   @id @default(cuid())
  title       String
  startTime   DateTime @map("start_time")
  endTime     DateTime? @map("end_time")
  location    String
  description String
  status      String   @default("upcoming")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("events")
}

model Testimonial {
  id           String   @id @default(cuid())
  name         String
  title        String
  organization String
  quote        String
  category     String?
  photoUrl     String?  @map("photo_url")
  approved     Boolean  @default(false)
  featured     Boolean  @default(false)
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("testimonials")
}

model SpeakingTopic {
  id          String @id @default(cuid())
  title       String
  slug        String @unique
  description String
  outcomes    String
  audienceFit String @map("audience_fit")

  @@map("speaking_topics")
}

model CoachingPackage {
  id            String  @id @default(cuid())
  title         String
  description   String
  priceCents    Int     @map("price_cents")
  sessionsCount Int     @map("sessions_count")
  active        Boolean @default(true)

  @@map("coaching_packages")
}

// ─── Leads ───────────────────────────────────────────────

enum LeadType {
  SPEAKING
  COACHING
  CONTACT
}

enum LeadStatus {
  NEW
  CONTACTED
  BOOKED
  CLOSED
}

model Lead {
  id        String     @id @default(cuid())
  type      LeadType
  payload   String     // JSON string
  status    LeadStatus @default(NEW)
  notes     String?
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  @@map("leads")
}

model NewsletterSubscriber {
  id             String    @id @default(cuid())
  email          String    @unique
  source         String    @default("website")
  subscribedAt   DateTime  @default(now()) @map("subscribed_at")
  unsubscribedAt DateTime? @map("unsubscribed_at")

  @@map("newsletter_subscribers")
}

// ─── FAQs ────────────────────────────────────────────────

model Faq {
  id        String @id @default(cuid())
  question  String
  answer    String
  category  String
  sortOrder Int    @default(0) @map("sort_order")
  productId String? @map("product_id")

  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@map("faqs")
}

// ─── Courses / Premium ───────────────────────────────────

model CourseModule {
  id        String @id @default(cuid())
  courseId   String @map("course_id")
  title     String
  content   String
  sortOrder Int    @default(0) @map("sort_order")

  progress CourseProgress[]

  @@map("course_modules")
}

model CourseProgress {
  id          String    @id @default(cuid())
  userId      String    @map("user_id")
  moduleId    String    @map("module_id")
  completedAt DateTime? @map("completed_at")

  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  module CourseModule  @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleId])
  @@map("course_progress")
}

// ─── Settings & Audit ────────────────────────────────────

model SiteSetting {
  key   String @id
  value String // JSON string

  @@map("site_settings")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?  @map("user_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id")
  details    String?  // JSON string
  createdAt  DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("audit_log")
}
