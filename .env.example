# Database (Neon free tier or Supabase free tier)
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/nickparks?sslmode=require

# Auth
AUTH_SECRET=generate-a-random-secret-here
AUTH_URL=http://localhost:3000

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Email (Resend free tier: 100 emails/day)
RESEND_API_KEY=re_...
EMAIL_FROM=hello@nickparks.com

# App
APP_URL=http://localhost:3000
NODE_ENV=development

# Azure Blob Storage (optional, for digital downloads)
AZURE_STORAGE_ACCOUNT_NAME=nickparksstorage
AZURE_STORAGE_ACCOUNT_KEY=
AZURE_STORAGE_CONTAINER=downloads
