# Database (optional for Vercel Hobby + Resend email delivery)
# Add a real Postgres URL only if you want form submissions saved as leads.
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/nickparks?sslmode=require

# Auth (optional if you enable protected/admin features)
AUTH_SECRET=generate-a-random-secret-here
NEXTAUTH_URL=http://localhost:3000

# Stripe (optional)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Email delivery (SMTP preferred, Resend optional fallback)
EMAIL_FROM=nparks@lonelesswolf.com
BOOKING_EMAIL_TO=nicholasparks14@gmail.com
SMTP_HOST=smtp.your-email-provider.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=nparks@lonelesswolf.com
SMTP_PASSWORD=your-smtp-password-or-app-password
RESEND_API_KEY=re_...

# App
APP_URL=http://localhost:3000
NODE_ENV=development

# Static export toggle (used by the GitHub Pages workflow only)
GITHUB_PAGES=false

# Azure Blob Storage (optional, for digital downloads)
AZURE_STORAGE_ACCOUNT_NAME=nickparksstorage
AZURE_STORAGE_ACCOUNT_KEY=
AZURE_STORAGE_CONTAINER=downloads
